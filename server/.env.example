# ─────────────────────────────────────────────────────────
#  LOCORA – Server Environment Variables Template
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Locora

# ── Client Origin (CORS) ──────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── JWT Auth ──────────────────────────────────────────────
# Short-lived access token (15 min) — generate a long random secret
JWT_SECRET=<generate_random_64_char_hex>

# Long-lived refresh token (30 days, stored in MongoDB + HttpOnly cookie)
REFRESH_TOKEN_SECRET=<generate_random_64_char_hex>

# ── Email / OTP (Brevo) ───────────────────────────────────
# 1. Create a free account at https://app.brevo.com
# 2. Go to SMTP & API → API Keys → Generate a new key
# 3. Paste it below
BREVO_API_KEY=<your_brevo_api_key>
EMAIL_FROM="Locora" <noreply@locora.app>
