# ─────────────────────────────────────────────────────────
#  LOCORA – Client Environment Variables
#  Copy to .env for local dev or set in Vercel dashboard
# ─────────────────────────────────────────────────────────

# Leave empty for local dev (Vite proxy handles /api and /socket.io)
# Set to your Render backend URL for production, e.g.:
# VITE_API_URL=https://locora-api.onrender.com
VITE_API_URL=
